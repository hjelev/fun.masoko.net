---
permalink: /search.json
layout: null
sitemap: false
---
{%- assign jokes = site.jokes | sort: "date" | reverse -%}
[
{%- for j in jokes -%}
  {%- assign body = j.content | markdownify | strip_html | normalize_whitespace -%}
  {%- capture haystack -%}{{ j.title }} {{ j.category_name }} {{ j.tags | join: " " }} {{ body }}{%- endcapture -%}
  {
    "title": {{ j.title | jsonify }},
    "category": {{ j.category | jsonify }},
    "category_name": {{ j.category_name | jsonify }},
    "tags": {{ j.tags | jsonify }},
    "url": {{ j.url | relative_url | jsonify }},
    "html": {{ j.content | markdownify | jsonify }},
    "search": {{ haystack | downcase | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
